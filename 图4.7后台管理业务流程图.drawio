        <mxCell id="orderExec" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="执行取消订单、发货等处理，并更新订单状态与履约信息" vertex="1">
