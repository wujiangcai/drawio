<mxfile host="app.diagrams.net" agent="Mozilla/5.0">
  <diagram id="fig-4-7-admin-flow" name="图4.7 后台管理业务流程图">
    <mxGraphModel dx="1202" dy="816" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" value="后台管理业务流程图" vertex="1">
          <mxGeometry height="46" width="500" x="334" y="20" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="开始" vertex="1">
          <mxGeometry height="50" width="120" x="524" y="90" as="geometry" />
        </mxCell>
        <mxCell id="loginReq" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="管理员通过后台登录接口提交账号与密码" vertex="1">
          <mxGeometry height="60" width="305" x="431.5" y="184" as="geometry" />
        </mxCell>
        <mxCell id="checkRole" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="校验登录信息及用户角色是否为管理员" vertex="1">
          <mxGeometry height="100" width="360" x="404" y="280" as="geometry" />
        </mxCell>
        <mxCell id="loginFail" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="拒绝访问后台页面并返回登录失败或权限不足信息" vertex="1">
          <mxGeometry height="50" width="240" x="804" y="305" as="geometry" />
        </mxCell>
        <mxCell id="enterAdmin" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="登录成功，进入后台管理首页" vertex="1">
          <mxGeometry height="55" width="225" x="471.5" y="416" as="geometry" />
        </mxCell>
        <mxCell id="chooseModule" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="选择后台管理功能模块" vertex="1">
          <mxGeometry height="90" width="300" x="434" y="520" as="geometry" />
        </mxCell>
        <mxCell id="userMng" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="用户管理&#xa;查看用户信息、维护用户状态、创建后台账号、重置用户密码" vertex="1">
          <mxGeometry height="95" width="240" x="54" y="690" as="geometry" />
        </mxCell>
        <mxCell id="bookCateMng" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="图书与分类管理&#xa;新增图书、修改图书信息、调整上下架状态、维护分类结构" vertex="1">
          <mxGeometry height="95" width="260" x="334" y="690" as="geometry" />
        </mxCell>
        <mxCell id="bannerMng" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="轮播图管理&#xa;更新首页轮播图资源，支持宣传展示与运营活动" vertex="1">
          <mxGeometry height="95" width="240" x="634" y="690" as="geometry" />
        </mxCell>
        <mxCell id="orderMng" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="订单管理&#xa;查看订单列表与详情，并根据订单状态执行取消、发货等操作" vertex="1">
          <mxGeometry height="95" width="240" x="914" y="690" as="geometry" />
        </mxCell>
        <mxCell id="back1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" value="操作完成后返回后台首页" vertex="1">
          <mxGeometry height="45" width="200" x="74" y="835" as="geometry" />
        </mxCell>
        <mxCell id="back2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" value="操作完成后返回后台首页" vertex="1">
          <mxGeometry height="45" width="200" x="364" y="835" as="geometry" />
        </mxCell>
        <mxCell id="back3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" value="操作完成后返回后台首页" vertex="1">
          <mxGeometry height="45" width="200" x="654" y="835" as="geometry" />
        </mxCell>
        <mxCell id="orderCheck" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="订单状态是否满足当前操作条件" vertex="1">
          <mxGeometry height="95" width="300" x="884" y="835" as="geometry" />
        </mxCell>
        <mxCell id="orderReject" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" value="不允许执行操作，提示状态流转不合法&#xa;如未支付订单不能直接发货，已完成订单不能回退，非待发货订单不能执行发货" vertex="1">
          <mxGeometry height="90" width="360" x="854" y="980" as="geometry" />
