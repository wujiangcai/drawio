<mxfile host="app.diagrams.net" agent="Mozilla/5.0" version="24.7.17">
  <diagram id="user-login-sequence-diagram" name="用户登录时序图">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 标题 -->
        <mxCell id="title" value="用户登录时序图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="434" y="20" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- 前端 -->
        <mxCell id="frontend" value="前端（Login.vue）" style="swimlane;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="1120" height="360" as="geometry" />
        </mxCell>

        <!-- 后端 -->
        <mxCell id="backend" value="后端（FrontAuthController、UserServiceImpl）" style="swimlane;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;fontSize=13;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="450" width="1120" height="360" as="geometry" />
        </mxCell>

        <!-- 用户填写用户名和密码 -->
        <mxCell id="frontendInput" value="用户输入用户名和密码" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 发送请求 -->
        <mxCell id="sendRequest" value="调用 frontAuthApi.login，发送请求到 /api/front/auth/login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 后端接收请求 -->
        <mxCell id="backendReceive" value="FrontAuthController.login 接收请求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 查询用户记录 -->
        <mxCell id="queryUser" value="UserMapper 查询用户名对应的用户记录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 校验密码 -->
        <mxCell id="checkPassword" value="PasswordEncoder.matches 对密码进行校验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 判断用户状态 -->
        <mxCell id="checkStatus" value="判断用户是否处于禁用状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1200" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 密码校验通过 -->
        <mxCell id="passwordValid" value="密码校验通过" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="checkPassword" target="generateToken">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 密码校验失败 -->
        <mxCell id="passwordInvalid" value="密码校验失败" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="checkPassword" target="passwordError">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 生成登录令牌 -->
        <mxCell id="generateToken" value="JwtUtil 生成登录令牌" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1400" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 将用户信息写入 token -->
        <mxCell id="tokenClaims" value="将用户编号与角色写入 Token 的 claims 中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1600" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 返回认证结果 -->
        <mxCell id="returnResult" value="返回 token、角色、用户编号、用户名" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1800" y="120" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 将数据写入本地存储 -->
        <mxCell id="storeLocal" value="写入本地存储（token、角色、用户编号、用户名）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1800" y="240" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 登录成功 -->
        <mxCell id="loginSuccess" value="登录成功，跳转到目标页面" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="2000" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 错误处理 -->
        <mxCell id="loginError" value="登录失败，显示错误信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="2000" y="360" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 各节点之间的箭头 -->
        <mxCell id="arrows" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="sendRequest" target="backendReceive">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 成功箭头 -->
        <mxCell id="successArrows" value="认证成功" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="returnResult" target="loginSuccess">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 错误箭头 -->
        <mxCell id="errorArrows" value="认证失败" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="returnResult" target="loginError">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>