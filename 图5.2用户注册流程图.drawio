        <mxCell id="duplicateFail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" value="返回重复错误" vertex="1">
          <mxGeometry height="40" width="110" x="740" y="590" as="geometry" />
