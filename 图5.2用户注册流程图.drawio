        </mxCell>
        <mxCell id="paramValidate" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="RegisterRequest 注解校验参数合法性" vertex="1">
          <mxGeometry height="60" width="200" x="484" y="490" as="geometry" />
        </mxCell>
        <mxCell id="arrowParamFail" edge="1" parent="1" source="paramValidate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" target="paramFail" value="校验失败">
