          <mxGeometry height="60" width="240" x="464" y="580" as="geometry" />
        </mxCell>
        <mxCell id="arrowDupFail" edge="1" parent="1" source="checkDuplicate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" target="duplicateFail" value="已存在">
