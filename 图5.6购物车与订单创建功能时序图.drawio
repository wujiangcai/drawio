<mxfile host="app.diagrams.net" agent="Mozilla/5.0" version="24.7.17">
  <diagram id="cart-order-creation-sequence-diagram" name="购物车与订单创建时序图">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 标题 -->
        <mxCell id="title" value="购物车与订单创建时序图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="434" y="20" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- 前端 -->
        <mxCell id="frontend" value="前端（BookDetail.vue, Cart.vue, OrderCreate.vue）" style="swimlane;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="1120" height="360" as="geometry" />
        </mxCell>

        <!-- 后端 -->
        <mxCell id="backend" value="后端（FrontCartController, CartService, FrontOrderController, OrderServiceImpl）" style="swimlane;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;fontSize=13;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="450" width="1120" height="360" as="geometry" />
        </mxCell>

        <!-- 图书详情页面 -->
        <mxCell id="bookDetailPage" value="图书详情页面（BookDetail.vue）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 点击“加入购物车”按钮 -->
        <mxCell id="addToCart" value="点击“加入购物车”按钮" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 调用加入购物车接口 -->
        <mxCell id="cartApiAdd" value="调用 frontCartApi.add 接口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 后端接收请求 -->
        <mxCell id="cartControllerAdd" value="FrontCartController.add 接收请求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="450" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 调用 CartService 添加商品 -->
        <mxCell id="cartServiceAdd" value="CartService.add 新增或更新购物车记录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="450" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 校验商品库存与状态 -->
        <mxCell id="checkProductAvailability" value="校验商品是否存在、上架与库存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="450" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 返回操作结果 -->
        <mxCell id="cartApiResponse" value="返回购物车操作结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1200" y="450" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 购物车页面 -->
        <mxCell id="cartPage" value="购物车页面（Cart.vue）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 修改商品数量 -->
        <mxCell id="updateCartQuantity" value="修改商品数量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 调用修改数量接口 -->
        <mxCell id="cartApiUpdate" value="调用 /api/front/cart/{id} 接口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 删除商品 -->
        <mxCell id="deleteCartItem" value="删除购物车商品" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 调用删除接口 -->
        <mxCell id="cartApiDelete" value="调用 DELETE 接口移除商品" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 提交订单 -->
        <mxCell id="submitOrder" value="点击“去结算”按钮" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1200" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 获取地址列表 -->
        <mxCell id="getAddressList" value="获取地址列表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1400" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 创建订单 -->
        <mxCell id="createOrder" value="调用 frontOrderApi.create 创建订单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1600" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 后端接收创建订单请求 -->
        <mxCell id="orderControllerCreate" value="FrontOrderController.create 接收创建订单请求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="600" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 查询购物车 -->
        <mxCell id="checkCart" value="查询购物车记录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="600" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 计算订单总金额 -->
        <mxCell id="calculateOrderAmount" value="计算订单总金额" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="600" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 创建订单 -->
        <mxCell id="createOrderRecord" value="创建订单主表和订单明细表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1200" y="600" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 返回订单信息 -->
        <mxCell id="orderResponse" value="返回订单信息（待支付状态）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1400" y="600" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 各节点之间的箭头 -->
        <mxCell id="arrows" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="addToCart" target="cartApiAdd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 购物车操作 -->
        <mxCell id="arrow1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="cartApiAdd" target="cartControllerAdd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 修改数量 -->
        <mxCell id="arrow2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="updateCartQuantity" target="cartApiUpdate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 删除商品 -->
        <mxCell id="arrow3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="deleteCartItem" target="cartApiDelete">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 订单创建 -->
        <mxCell id="arrow4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="submitOrder" target="getAddressList">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 订单处理 -->
        <mxCell id="arrow5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="getAddressList" target="createOrder">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>