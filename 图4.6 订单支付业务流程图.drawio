<mxfile host="app.diagrams.net" agent="Mozilla/5.0">
  <diagram id="fig-4-6-pay-flow" name="图4.6 订单支付业务流程图">
    <mxGraphModel dx="1572" dy="1068" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" value="订单支付业务流程图" vertex="1">
          <mxGeometry height="46" width="460" x="354" y="30" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="开始" vertex="1">
          <mxGeometry height="50" width="120" x="524" y="100" as="geometry" />
        </mxCell>
        <mxCell id="reqPay" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="对待支付订单发起支付请求" vertex="1">
          <mxGeometry height="60" width="192" x="489" y="185" as="geometry" />
        </mxCell>
        <mxCell id="checkOwner" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="校验订单是否属于当前登录用户" vertex="1">
          <mxGeometry height="90" width="248" x="460" y="290" as="geometry" />
        </mxCell>
        <mxCell id="ownerFail" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="拒绝支付请求并返回错误信息" vertex="1">
          <mxGeometry height="50" width="220" x="794" y="310" as="geometry" />
        </mxCell>
        <mxCell id="checkStatus" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="订单状态是否为“待支付”" vertex="1">
          <mxGeometry height="90" width="270" x="450" y="430" as="geometry" />
        </mxCell>
        <mxCell id="statusFail" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="终止处理，提示订单不可支付" vertex="1">
          <mxGeometry height="50" width="220" x="794" y="450" as="geometry" />
        </mxCell>
        <mxCell id="createForm" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="调用支付宝支付接口，生成支付表单并返回前端" vertex="1">
          <mxGeometry height="60" width="344" x="413" y="572" as="geometry" />
        </mxCell>
        <mxCell id="jumpAli" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="前端自动提交表单，跳转至支付宝支付页面，由用户完成付款" vertex="1">
          <mxGeometry height="60" width="381" x="394" y="671" as="geometry" />
        </mxCell>
        <mxCell id="keepPending" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="支付过程中订单状态仍保持为“待支付”，系统不提前更新订单状态，也不预先扣减库存" vertex="1">
          <mxGeometry height="70" width="499" x="335.5" y="774" as="geometry" />
        </mxCell>
        <mxCell id="notify" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="支付宝向系统异步通知地址发送支付结果通知" vertex="1">
          <mxGeometry height="60" width="299" x="434.5" y="880" as="geometry" />
        </mxCell>
        <mxCell id="checkCallback" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="校验回调数据合法性" vertex="1">
          <mxGeometry height="100" width="167" x="501.5" y="975" as="geometry" />
        </mxCell>
        <mxCell id="callbackFail" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="回调校验失败，拒绝处理并记录异常信息" vertex="1">
          <mxGeometry height="50" width="220" x="804" y="1005" as="geometry" />
        </mxCell>
        <mxCell id="idempotent" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="是否已完成支付处理" vertex="1">
          <mxGeometry height="90" width="171" x="498.5" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="repeatReturn" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="已处理订单直接返回成功结果，不重复执行后续逻辑" vertex="1">
          <mxGeometry height="50" width="260" x="794" y="1140" as="geometry" />
        </mxCell>
        <mxCell id="updateOrder" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="在事务中更新订单状态为“待发货”，记录支付时间、支付宝交易号等支付信息" vertex="1">
          <mxGeometry height="70" width="468" x="350" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="deductStock" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="执行库存扣减，防止超卖，并保证订单与库存数据一致" vertex="1">
          <mxGeometry height="60" width="342" x="413" y="1368" as="geometry" />
        </mxCell>
        <mxCell id="returnSuccess" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="返回支付回调处理成功结果" vertex="1">
          <mxGeometry height="50" width="187" x="491.5" y="1469" as="geometry" />
        </mxCell>
        <mxCell id="end" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="结束" vertex="1">
