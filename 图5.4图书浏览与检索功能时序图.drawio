        <!-- 查询结果 -->
        <mxCell id="arrow4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="backendReceive" target="bookSearch">
          <mxGeometry relative="1" as="geometry" />
