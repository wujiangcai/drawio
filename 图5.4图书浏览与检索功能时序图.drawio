        <!-- 渲染页面 -->
        <mxCell id="arrow6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="returnResult" target="renderList">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 渲染分页 -->
        <mxCell id="arrow7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="renderList" target="renderPagination">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 点击图书 -->
        <mxCell id="arrow8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="bookClick" target="bookDetailApi">
