          <mxGeometry x="1000" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 各节点之间的箭头 -->
        <mxCell id="arrows" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="homePageLoad" target="carouselApi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 轮播图接口 -->
        <mxCell id="arrow1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="carouselApi" target="bookListApi">
