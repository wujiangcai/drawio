        <!-- 分类接口 -->
        <mxCell id="arrow3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="categoryApi" target="backendReceive">
          <mxGeometry relative="1" as="geometry" />
