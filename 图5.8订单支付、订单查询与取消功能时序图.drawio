<mxfile host="app.diagrams.net" agent="Mozilla/5.0" version="24.7.17">
  <diagram id="order-payment-query-sequence-diagram" name="订单支付与查询时序图">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 标题 -->
        <mxCell id="title" value="订单支付与查询时序图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="434" y="20" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- 前端 -->
        <mxCell id="frontend" value="前端（OrderList.vue, OrderDetail.vue）" style="swimlane;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="1120" height="360" as="geometry" />
        </mxCell>

        <!-- 后端 -->
        <mxCell id="backend" value="后端（OrderServiceImpl, AlipayController）" style="swimlane;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;fontSize=13;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="450" width="1120" height="360" as="geometry" />
        </mxCell>

        <!-- 订单列表页面 -->
        <mxCell id="orderListPage" value="订单列表页面（OrderList.vue）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 点击支付按钮 -->
        <mxCell id="clickPayButton" value="点击支付按钮" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 调用支付接口 -->
        <mxCell id="payApi" value="调用 frontOrderApi.pay 接口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 后端接收支付请求 -->
        <mxCell id="payRequestReceived" value="OrderServiceImpl.pay 接收支付请求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="450" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 校验订单 -->
        <mxCell id="orderValidation" value="验证订单归属、状态和商品有效性" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="450" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 构造支付请求 -->
        <mxCell id="constructPaymentRequest" value="构造支付请求并返回表单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="450" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 前端插入支付表单并提交 -->
        <mxCell id="submitPaymentForm" value="前端插入支付表单并提交" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1200" y="450" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 支付宝支付页面 -->
        <mxCell id="alipayPage" value="跳转到支付宝支付页面" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1400" y="450" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 支付成功处理 -->
        <mxCell id="paymentSuccess" value="支付成功处理（notify, returnUrl）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="600" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 校验支付信息 -->
        <mxCell id="validatePaymentInfo" value="校验支付签名、金额等" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="600" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 支付成功后的业务处理 -->
        <mxCell id="paymentBusinessProcessing" value="支付成功后的业务处理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="600" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 返回支付成功结果 -->
        <mxCell id="paymentSuccessResult" value="返回支付成功结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1200" y="600" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 订单查询 -->
        <mxCell id="orderQuery" value="订单查询（/api/front/orders）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 订单详情查询 -->
        <mxCell id="orderDetailQuery" value="查询订单详情（/api/front/orders/{id}）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 取消订单 -->
        <mxCell id="cancelOrder" value="取消订单（/api/front/orders/{id}/cancel）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 后端接收订单查询 -->
        <mxCell id="orderQueryBackend" value="接收订单查询请求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="750" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- 订单查询返回结果 -->
        <mxCell id="orderQueryResult" value="返回订单列表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="750" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 订单详情查询 -->
        <mxCell id="orderDetailResult" value="返回订单详情" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="750" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 订单取消 -->
        <mxCell id="orderCancelResult" value="返回订单取消结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1200" y="750" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 各节点之间的箭头 -->
        <mxCell id="arrows1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="clickPayButton" target="payApi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 支付请求处理 -->
        <mxCell id="arrows2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="payApi" target="payRequestReceived">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 订单校验 -->
        <mxCell id="arrows3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="payRequestReceived" target="orderValidation">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 支付请求构造 -->
        <mxCell id="arrows4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="orderValidation" target="constructPaymentRequest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 前端提交支付表单 -->
        <mxCell id="arrows5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="constructPaymentRequest" target="submitPaymentForm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 支付宝支付 -->
        <mxCell id="arrows6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="submitPaymentForm" target="alipayPage">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 支付成功通知 -->
        <mxCell id="arrows7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="alipayPage" target="paymentSuccess">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 校验支付信息 -->
        <mxCell id="arrows8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="paymentSuccess" target="validatePaymentInfo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 订单成功处理 -->
        <mxCell id="arrows9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="validatePaymentInfo" target="paymentBusinessProcessing">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 支付成功返回 -->
        <mxCell id="arrows10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="paymentBusinessProcessing" target="paymentSuccessResult">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 查询订单 -->
        <mxCell id="arrows11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="orderQuery" target="orderQueryBackend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 返回订单查询结果 -->
        <mxCell id="arrows12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="orderQueryBackend" target="orderQueryResult">
          <mxGeometry relative="1" as="geometry" />
