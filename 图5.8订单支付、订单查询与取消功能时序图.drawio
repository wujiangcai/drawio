        <!-- 取消订单 -->
        <mxCell id="arrows14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="cancelOrder" target="orderCancelResult">
          <mxGeometry relative="1" as="geometry" />
