        <!-- 查询订单详情 -->
        <mxCell id="arrows13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;" edge="1" parent="1" source="orderDetailQuery" target="orderDetailResult">
          <mxGeometry relative="1" as="geometry" />
